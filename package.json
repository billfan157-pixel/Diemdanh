{
  "name": "diemdanh",
  "version": "1.0.0",
  "private": true,
  "description": "Sổ Điểm Giáo Lý — app web tính điểm giáo lý theo lớp",
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "lint": "eslint src tests",
    "format": "prettier --check \"src/**/*.js\" \"tests/**/*.js\"",
    "format:fix": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "globals": "^15.15.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.5",
    "vitest": "^3.2.7"
  }
}
